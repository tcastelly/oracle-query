{
  "name": "oracle-query",
  "version": "1.0.0-beta.2",
  "description": "oracle query builder",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcastelly/oracle-query.git"
  },
  "license": "MIT",
  "author": "Thomas CASTELLY",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/backend.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./dist/dto": {
      "types": "./dist/dto.d.ts",
      "require": "./dist/dto.js",
      "import": "./dist/dto.js"
    },
    "./dto": {
      "types": "./dist/dto.d.ts",
      "require": "./dist/dto.js",
      "import": "./dist/dto.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/backend.d.ts",
  "scripts": {
    "afterbuild": "tsx scripts/afterbuild.ts",
    "beforebuild": "tsx scripts/beforeBuild.ts && npm run tsgo:export-types",
    "build": "npm run beforebuild && npm run build:webpack && npm run afterbuild",
    "build:webpack": "webpack --mode=production",
    "clean": "rimraf dist && rimraf types && rimraf coverage",
    "lint": "npm run tsgo:check-types && eslint scripts src tests",
    "lint:fix": "npm run tsgo:check-types && eslint --fix scripts src tests",
    "lint:quiet": "eslint --quiet \"{tests,src}/**/*.{js,ts,tsx,vue}\" && npm run tsgo:check-types",
    "precommit": "lint-staged",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "test": "NODE_OPTIONS=--unhandled-rejections=warn jest tests/** --no-cache",
    "tsgo:check-types": "tsgo --noemit",
    "tsgo:export-types": "tsgo --outDir types"
  },
  "dependencies": {
    "@jest/globals": "^30.4.1",
    "oracledb": "^7.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^8.0.1",
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tcy/eslint-rules": "^1.6.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/oracledb": "^7.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript/native-preview": "^7.0.0-dev.20260623.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^18.1.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "peerDependencies": {
    "oracledb": "*"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ]
}
